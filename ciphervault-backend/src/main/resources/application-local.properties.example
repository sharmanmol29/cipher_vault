# Copy to application-local.properties (same folder). That file is gitignored.
#
# Security: If these values ever leaked, rotate MySQL password and create a new Google OAuth client secret in Google Cloud Console.

spring.datasource.password=YOUR_MYSQL_PASSWORD

spring.security.oauth2.client.registration.google.client-id=YOUR_CLIENT_ID.apps.googleusercontent.com
spring.security.oauth2.client.registration.google.client-secret=YOUR_CLIENT_SECRET

# Used by app.jwt.secret in application.properties
JWT_SECRET=replace-with-long-random-secret-at-least-32-characters

# Used by app.encryption.master-key-base64 — Base64 of exactly 32 bytes
ENCRYPTION_MASTER_KEY_BASE64=YOUR_32_BYTE_KEY_BASE64
